# --- Database URLs (REQUIRED) ---
# DATABASE_URL: Use Supabase Connection Pooler (Port 6543) for Vercel/Serverless
# IMPORTANT: If your password has special characters like '@', you must URL encode them! (@ -> %40)
# Example: postgresql://postgres:mypassword%40123@db.ref.supabase.co:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:YOUR_ENCODED_PASSWORD@db.YOUR_ID.supabase.co:6543/postgres?pgbouncer=true"

# DIRECT_URL: Use Supabase Direct Connection (Port 5432) for migrations/local dev
DIRECT_URL="postgresql://postgres:YOUR_ENCODED_PASSWORD@db.YOUR_ID.supabase.co:5432/postgres"

# --- Supabase Credentials (REQUIRED) ---
VITE_SUPABASE_URL="https://YOUR_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Razorpay (REQUIRED) ---
RAZORPAY_KEY_ID="rzp_test_..."
RAZORPAY_KEY_SECRET="..."
VITE_RAZORPAY_KEY_ID="rzp_test_..."

# --- Cloudinary (REQUIRED) ---
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."
VITE_CLOUDINARY_CLOUD_NAME="..."

# --- Auth Configuration (REQUIRED) ---
JWT_SECRET="your-random-secret"
VITE_API_URL="https://your-app.vercel.app/api"
VITE_FRONTEND_URL="https://your-app.vercel.app"

# --- Email Service (OPTIONAL) ---
RESEND_API_KEY="re_..."
